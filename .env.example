# LLM configuration — copy to .env and set values as needed.
# Only providers with required keys set are enabled (Ollama is always enabled).

# --- Logging ---
# STORYWEAVER_LOG_LEVEL=DEBUG  # DEBUG|INFO|WARNING|ERROR
# STORYWEAVER_LLM_LOG_PATH=llm_calls.log  # Path for LLM call log (real-time)

# --- Expansion ---
# BEAT_MAX_BEATS=2  # Max beats before fallback to single-call SCENE expand

# --- Vetting ---
# VET_CONSISTENCY_MODE=single  # full | single (default) | multi

# --- Humanization (AI checker evasion) ---
# STORYWEAVER_HUMANIZE_OUTPUT=0   # 0|1|false|true — default 0 (off)
# STORYWEAVER_HUMANIZE_SCOPE=expansion_only  # expansion_only | expansion_and_precis | all

# --- Plan vs Write LLM (optional overrides) ---
# STORYWEAVER_LLM_DEFAULT=ollama  # Default provider: anthropic | gemini | openai | ollama. If unset, uses first configured.
# STORYWEAVER_LLM_PLAN=anthropic:claude-3-5-sonnet  # Optional. Plan tasks (precis, beats, vetting). Format: provider or provider:model
# STORYWEAVER_LLM_WRITE=ollama:llama3.2  # Optional. Write tasks (expansion prose, humanize). Format: provider or provider:model

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Google Gemini ---
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Ollama (local) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
