# LLM configuration — copy to .env and set values as needed.
# Only providers with required keys set are enabled (Ollama is always enabled).

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Google Gemini ---
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Ollama (local) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
